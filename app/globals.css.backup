/* Import fonts */
@import url("https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400;1,700&display=swap");

/* Tailwind v3 directives */
@tailwind base;
@tailwind components;
@tailwind utilities;

@layer components {
  .heading-1 {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    line-height: 1.15;
    letter-spacing: -0.03em;
    font-weight: 700;
  }
  .heading-2 {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    line-height: 1.2;
    letter-spacing: -0.025em;
    font-weight: 600;
  }
  .heading-3 {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    line-height: 1.25;
    letter-spacing: -0.02em;
    font-weight: 600;
  }
  .heading-4 {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    line-height: 1.4;
    letter-spacing: -0.01em;
    font-weight: 600;
  }
  .body-base {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.65;
    letter-spacing: 0;
    font-weight: 400;
  }
  .label-ui {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    line-height: 1.4;
    letter-spacing: 0.02em;
    font-weight: 500;
  }
  .caption {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    line-height: 1.5;
    letter-spacing: 0.03em;
    font-weight: 400;
  }
}

:root {
  color-scheme: light dark;
  font-synthesis: none;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;

  --radius: 0.625rem;

  --shadow-2xs: 0 1px rgb(0 0 0 / 0.05);
  --shadow-xs: 0 1px 2px 0 rgb(0 0 0 / 0.05);
  --shadow-sm: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
  --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
  --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
  --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
  --shadow-2xl: 0 25px 50px -12px rgb(0 0 0 / 0.25);

  --font-sans: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
  --font-serif: 'Libre Baskerville', ui-serif, Georgia, serif;
  --font-mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;

  --text-xs: 0.75rem;
  --text-sm: 0.8125rem;
  --text-base: 0.9375rem;
  --text-lg: 1.125rem;
  --text-xl: 1.375rem;
  --text-2xl: 1.75rem;
  --text-3xl: 2.25rem;

  --leading-tight: 1.15;
  --leading-snug: 1.2;
  --leading-normal: 1.5;
  --leading-relaxed: 1.6;

/* ─── CPMSL palette mapped to shadcn CSS vars (HSL format) ─────────── */
  /* Source: docs/ui/design-tokens.md §1                                  */

  --background: 40 14% 98%;              /* neutral-50  #FAFAF8 */
  --foreground: 30 8% 11%;               /* neutral-900 #1E1A17 */

  --card: 0 0% 100%;                     /* white */
  --card-foreground: 30 8% 11%;          /* neutral-900 */

  --popover: 0 0% 100%;
  --popover-foreground: 30 8% 11%;

  --primary: 209 19% 44%;                /* primary-500 #5A7085 */
  --primary-foreground: 0 0% 100%;       /* white */

  --secondary: 40 25% 92%;               /* secondary-100 #F0EBDF */
  --secondary-foreground: 35 22% 39%;    /* secondary-700 #7A6E50 */

  --muted: 30 8% 95%;                    /* neutral-100 #F5F4F2 */
  --muted-foreground: 30 5% 45%;         /* neutral-500 #78756F */

  --accent: 40 25% 92%;                  /* secondary-100 */
  --accent-foreground: 35 22% 39%;       /* secondary-700 */

  --destructive: 0 54% 50%;              /* error #C43C3C */
  --destructive-foreground: 0 0% 100%;

  --border: 30 6% 90%;                   /* neutral-200 #E8E6E3 */
  --input: 30 5% 81%;                    /* neutral-300 #D1CECC */
  --ring: 209 19% 44%;                   /* primary-500 */

  --chart-1: 209 19% 44%;                /* primary-500 */
  --chart-2: 35 28% 67%;                 /* secondary-400 */
  --chart-3: 142 47% 33%;                /* success */
  --chart-4: 37 77% 43%;                 /* warning */
  --chart-5: 210 62% 43%;                /* info */

  --sidebar: 205 17% 21%;                /* primary-800 #2A3740 */
  --sidebar-foreground: 200 28% 85%;     /* primary-200 #B3C7D5 */
  --sidebar-primary: 35 28% 67%;         /* secondary-400 (accent on active) */
  --sidebar-primary-foreground: 0 0% 100%;
  --sidebar-accent: 205 18% 28%;         /* primary-700 #3A4A57 */
  --sidebar-accent-foreground: 0 0% 100%;
  --sidebar-border: 205 18% 28%;
  --sidebar-ring: 35 28% 67%;            /* secondary-400 */
}

.dark {
  --background: 240 10% 3.9%;
  --foreground: 0 0% 98%;
  --card: 240 10% 3.9%;
  --card-foreground: 0 0% 98%;
  --popover: 240 10% 3.9%;
  --popover-foreground: 0 0% 98%;
  --primary: 0 0% 98%;
  --primary-foreground: 240 5.9% 10%;
  --secondary: 240 3.7% 15.9%;
  --secondary-foreground: 0 0% 98%;
  --muted: 240 3.7% 15.9%;
  --muted-foreground: 240 5% 64.9%;
  --accent: 240 3.7% 15.9%;
  --accent-foreground: 0 0% 98%;
  --destructive: 0 62.8% 30.6%;
  --destructive-foreground: 0 0% 98%;
  --border: 240 3.7% 15.9%;
  --input: 240 3.7% 15.9%;
  --ring: 240 4.9% 83.9%;
  --chart-1: 220 70% 50%;
  --chart-2: 160 60% 45%;
  --chart-3: 30 80% 55%;
  --chart-4: 280 65% 60%;
  --chart-5: 340 75% 55%;
  --sidebar: 223.8 0% 9.1%;
  --sidebar-foreground: 223.8 0% 98%;
  --sidebar-primary: 225.3 84.1% 49%;
  --sidebar-primary-foreground: 223.8 0% 98%;
  --sidebar-accent: 223.8 0% 14.9%;
  --sidebar-accent-foreground: 223.8 0% 98%;
  --sidebar-border: 223.8 0% 15.5%;
  --sidebar-ring: 223.8 0% 32.2%;
}

body {
  font-family: var(--font-sans);
  font-size: 15px;
  line-height: 1.65;
  font-weight: 400;
  color: hsl(var(--foreground));
  background-color: hsl(var(--background));
}
